# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Windows-specific files keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files — never touch
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.zip   binary
*.gz    binary
*.tar   binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
*.a     binary
*.o     binary
*.db    binary
*.sqlite binary
*.vsix  binary
