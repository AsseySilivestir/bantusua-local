{
  "Function definition": {
    "prefix": "def",
    "body": [
      "def ${1:name}(${2:args}) {",
      "    ${3:// body}",
      "    return ${4:null};",
      "}"
    ],
    "description": "Define a Bantu function"
  },
  "Variable declaration": {
    "prefix": "var",
    "body": [
      "$${1:name} = ${2:value};"
    ],
    "description": "Declare a Bantu variable with $"
  },
  "Typed variable": {
    "prefix": "tvar",
    "body": [
      "${1|number,string,bool,list,dict,any|} $${2:name} = ${3:value};"
    ],
    "description": "Declare a typed Bantu variable"
  },
  "Class definition": {
    "prefix": "class",
    "body": [
      "class ${1:Name} {",
      "    public def ${2:method}() {",
      "        ${3:// body}",
      "    }",
      "}"
    ],
    "description": "Define a Bantu class"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "    ${2:// then}",
      "} else {",
      "    ${3:// else}",
      "}"
    ],
    "description": "If-else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ($${1:i} = 0; $${1:i} < ${2:10}; $${1:i} += 1) {",
      "    ${3:// body}",
      "}"
    ],
    "description": "Classic for loop"
  },
  "Each loop": {
    "prefix": "each",
    "body": [
      "each ($${1:item} in ${2:list}) {",
      "    ${3:// body}",
      "}"
    ],
    "description": "Each iteration over a list"
  },
  "Try-catch": {
    "prefix": "try",
    "body": [
      "try {",
      "    ${1:// risky code}",
      "} catch {",
      "    ${2:// handler}",
      "}"
    ],
    "description": "Try-catch block"
  },
  "Include module": {
    "prefix": "include",
    "body": [
      "include \"./${1:module}.b\"${2: as ${3:alias}};"
    ],
    "description": "Include a Bantu module (v1.2.1)"
  },
  "Sua HTTP server": {
    "prefix": "sua.server",
    "body": [
      "sua.server.get(\"/${1:path}\", def($req, $res) {",
      "    $res.json({ \"ok\": true, \"msg\": \"${2:hello}\" });",
      "});",
      "",
      "sua.server.listen(${3:3000});"
    ],
    "description": "Sua HTTP server route + listen"
  },
  "Sua SQLite": {
    "prefix": "sua.sqlite",
    "body": [
      "sua.sqlite.connect(\"${1:app.db}\");",
      "sua.sqlite.exec(\"CREATE TABLE IF NOT EXISTS ${2:items} (id INTEGER PRIMARY KEY, name TEXT)\");",
      "$rows = sua.sqlite.query(\"SELECT * FROM ${2:items}\");",
      "print($rows);"
    ],
    "description": "Sua SQLite boilerplate"
  },
  "Sua PostgreSQL": {
    "prefix": "sua.postgres",
    "body": [
      "sua.postgres.connect(\"host=localhost dbname=${1:app} user=${2:postgres} password=${3:secret}\");",
      "$rows = sua.postgres.query(\"SELECT * FROM ${4:users}\");",
      "print($rows);"
    ],
    "description": "Sua PostgreSQL connection"
  },
  "Sua MySQL": {
    "prefix": "sua.mysql",
    "body": [
      "sua.mysql.connect(\"${1:localhost}\", \"${2:root}\", \"${3:password}\", \"${4:app}\", 3306);",
      "$rows = sua.mysql.query(\"SELECT * FROM ${5:users}\");",
      "print($rows);"
    ],
    "description": "Sua MySQL connection"
  },
  "Sua WebRTC peer": {
    "prefix": "sua.webrtc.peer",
    "body": [
      "$peer = sua.webrtc.peer(\"${1:alice}\");",
      "$offer = sua.webrtc.createOffer(\"${1:alice}\");",
      "$chan = sua.webrtc.dataChannel(\"${2:chat}\");",
      "sua.webrtc.send(\"${2:chat}\", \"${3:hello}\");"
    ],
    "description": "Sua WebRTC peer setup (v1.2.1)"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(${1:\"hello\"});"
    ],
    "description": "Print to stdout"
  },
  "JSON parse / stringify": {
    "prefix": "json",
    "body": [
      "$obj = sua.json.parse(${1:\"{\\\"k\\\":1}\"});",
      "$str = sua.json.stringify(${2:$obj});"
    ],
    "description": "Sua JSON helpers"
  }
}
