{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "/*",
      "close": "*/",
      "notIn": [
        "string"
      ]
    }
  ],
  "autoCloseBefore": ";:.,=}])>` \n\t",
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "'",
      "'"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(//|/\\*\\*)\\s*#?region\\b",
      "end": "^\\s*(//|/\\*\\*)\\s*#?endregion\\b"
    }
  },
  "wordPattern": "(/?[$A-Za-z][\\w$.-]*)",
  "indentationRules": {
    "increaseIndentPattern": "^((?!\\/\\/).)*(\\{[^}\"']*$|\\([^)\"']*$|\\[[^\\]\"']*$)$",
    "decreaseIndentPattern": "^\\s*[}\\)\\]],?\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
      "afterText": "^\\s*\\*\\/$",
      "action": {
        "indent": "indentOutdent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\/\\*\\*\\s*$",
      "action": {
        "indent": "indentOutdent",
        "appendText": " * "
      }
    },
    {
      "beforeText": "^\\s*\\*\\s*$",
      "action": {
        "indent": "indentOutdent",
        "appendText": "* "
      }
    }
  ]
}
